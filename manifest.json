{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "icons": {
    "16": "assets/icons/icon-default-16.png",
    "32": "assets/icons/icon-default-32.png",
    "48": "assets/icons/icon-default-48.png",
    "128": "assets/icons/icon-default-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-default-16.png",
      "32": "assets/icons/icon-default-32.png",
      "48": "assets/icons/icon-default-48.png",
      "128": "assets/icons/icon-default-128.png"
    },
    "default_title": "ScamWarning — Click to scan this page"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/patterns.js", "content/content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.scamwarning.ai/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "minimum_chrome_version": "116"
}
